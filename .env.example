# Django (ядро / core)
# Згенеруйте унікальний ключ для production: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-in-production
DEBUG=True
# Через кому; для Docker додайте 0.0.0.0 якщо потрібно
ALLOWED_HOSTS=localhost,127.0.0.1

# База даних (django-environ)
# Локально (pgAdmin / Postgres на хості, порт як у docker-compose):
# DATABASE_URL=postgres://user:password@127.0.0.1:5432/cinema_db
# Усередині Docker Compose (сервіс db):
DATABASE_URL=postgres://user:password@db:5432/cinema_db

# CORS: якщо задано список URL — тільки вони (production). Якщо порожньо при DEBUG=True — дозволено всім (лише dev).
# Приклад для Angular:
# CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
